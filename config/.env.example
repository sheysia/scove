# VHome Phase 1 config. Copy to config/.env, chmod 600, fill ANTHROPIC_API_KEY yourself.
# Claude never writes the real key. Model IDs are placeholders: verify against
# the live /v1/models endpoint (run backend/verify_models.py) before trusting them.

# --- secrets (you fill) ---
ANTHROPIC_API_KEY=

# --- PIN protection (Phase 2, optional) ---
# Set a numeric PIN to protect access. Leave empty to skip.
SCOVE_PIN=

# --- models (placeholders, confirm with verify_models.py) ---
# Main voice. Sonnet-class for warmth/quality balance.
CLAUDE_CHAT_MODEL=claude-sonnet-4-6
# Cheap/fast helper tasks. Not used in Phase 1, reserved.
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001

# --- Phase 4 only, leave blank now (no Gemini in Phase 1) ---
# GEMINI_HELPER_MODEL=
# GEMINI_EMBEDDING_MODEL=
# GEMINI_API_KEY=

# --- paths ---
V_ROOT=/Users/sasha/V
VHOME_ROOT=/Users/sasha/V/VHome

# --- context tuning ---
# how many most-recent files to pull from each of 04_对话 / 06_日记
RECENT_DIALOGUE_COUNT=4
RECENT_DIARY_COUNT=3
# which voice variant to load: cold | mid | hot
VOICE_VARIANT=hot
# max tokens for a single reply
MAX_TOKENS=2048
