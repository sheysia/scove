# secrets: key lives only in config/.env (chmod 600), never committed
config/.env
.env

# runtime logs (not source)
logs/newhome/*.jsonl
logs/newhome/sessions/*.jsonl
logs/*.log

# live memory (runtime, not source; starred .md are also runtime)
memory/v/*.jsonl
memory/v/starred/*.md
memory/xiaheng/*.jsonl
memory/xiaheng/starred/*.md
memory/loggia/*.jsonl
memory/loggia/starred/*.md
memory/cc/*.jsonl
memory/cc/starred/*.md
memory/council/*.jsonl
memory/council/starred/*.md

# frozen memory snapshots are rebuildable from ~/V; keep them local
prompts/_cache/*.md

# python
__pycache__/
*.pyc
.venv/
venv/

# os
.DS_Store

# stray files at root (not source)
/*.png
memory/cc/transcripts/

# Docker build staging (soul files copied from ~/V)
build_soul/

# Cloud backups pulled from Fly
backups/
